ClientProjectWithClientView {
    id
    name
    client {
        id
        name
        #types {
            Organization {
                taxCode
            }
        }
    }
}

ClientProjectWithReusableClientView {
    id
    name
    client -> ClientImplicitCatchAllView
}

ClientProjectWithReusableParticipantsView {
    id
    name
    participants -> ClientImplicitCatchAllView
}

input ClientProjectWithReusableClientInput {
    id
    name
    client -> ClientPatchInput
}

input ClientProjectWithReusableParticipantsInput {
    id
    name
    participants -> ClientPatchInput
}
