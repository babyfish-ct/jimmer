import com.fasterxml.jackson.annotation.{JsonSubTypes, JsonTypeInfo, JsonTypeName}

ClientDefaultView {
    id
    name
    #types {
        default class Other {
        }
        Organization {
            taxCode
        }
    }
}

ClientImplicitDefaultView {
    id
    name
    #types {
        default {
        }
        Person {
            firstName
        }
    }
}

ClientImplicitCatchAllView {
    id
    name
    #types {
        Organization {
            taxCode
        }
    }
}

input ClientPatchInput {
    id
    name
    #types {
        Organization {
            taxCode
        }
    }
}

input ClientDiscriminatorInput {
    id
    type
    name
    #types {
        default {
        }
        Organization {
            taxCode
        }
    }
}

input ClientAliasedDiscriminatorInput {
    id
    type as kind
    name
    #types {
        default {
        }
        Organization {
            taxCode
        }
    }
}

@JsonTypeInfo(
    use = JsonTypeInfo.Id.NAME,
    include = JsonTypeInfo.As.PROPERTY,
    property = "customType"
)
input ClientCustomJsonTypeInfoInput {
    id
    name
    #types {
        Organization {
            taxCode
        }
    }
}

input ClientCustomJsonTypeNameInput {
    id
    name
    #types {
        @JsonTypeName("company")
        Organization {
            taxCode
        }
    }
}

@JsonSubTypes(value = [
    JsonSubTypes.Type(value = String.class)
])
input ClientCustomJsonSubTypesInput {
    id
    name
    #types {
        Organization {
            taxCode
        }
    }
}

input ClientExhaustiveInput {
    id
    name
    #types {
        #exhaustive
        Organization {
            taxCode
        }
        Person {
            firstName
            lastName
        }
    }
}
