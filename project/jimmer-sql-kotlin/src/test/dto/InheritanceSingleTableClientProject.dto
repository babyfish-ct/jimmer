export org.babyfish.jimmer.sql.kt.model.inheritance.singletable.KClientProject
    -> package org.babyfish.jimmer.sql.kt.model.inheritance.singletable.dto

import org.babyfish.jimmer.sql.kt.model.inheritance.singletable.dto.KClientImplicitCatchAllView
import org.babyfish.jimmer.sql.kt.model.inheritance.singletable.dto.KClientPatchInput

KClientProjectWithClientView {
    id
    name
    client {
        id
        name
        #types {
            KOrganization class Organization {
                taxCode
            }
        }
    }
}

KClientProjectWithReusableClientView {
    id
    name
    client -> KClientImplicitCatchAllView
}

input KClientProjectWithReusableClientInput {
    id
    name
    client -> KClientPatchInput
}
