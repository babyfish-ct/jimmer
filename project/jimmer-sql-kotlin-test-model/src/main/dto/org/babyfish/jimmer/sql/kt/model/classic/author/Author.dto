fragment ReusableAuthorProps {
    id
    firstName
    lastName
}

ReusableAuthorView {
    #include(ReusableAuthorProps)
}

input ReusableAuthorInput {
    #include(ReusableAuthorProps)
}

fragment ReusableAuthorSpecificationProps {
    like/i(firstName, lastName) as name
}

specification ReusableAuthorSpecification for Author {
    #include(ReusableAuthorSpecificationProps)
}

AuthorView {
    fullName
    fullName2
}
